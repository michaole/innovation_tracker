{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.4",
  "body": [
    {
      "type": "Container",
      "style": "warning",
      "items": [
        {
          "type": "TextBlock",
          "text": "⚠️ Non-Response Alert",
          "weight": "Bolder",
          "size": "Medium",
          "color": "Warning"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "{{POC_NAME}}",
      "weight": "Bolder",
      "size": "Default",
      "spacing": "Medium",
      "wrap": true
    },
    {
      "type": "FactSet",
      "spacing": "Small",
      "facts": [
        {
          "title": "SPOC",
          "value": "{{SPOC_UPN}}"
        },
        {
          "title": "Days since last update",
          "value": "{{DAYS_OVERDUE}}"
        },
        {
          "title": "Last known status",
          "value": "{{LAST_KNOWN_RAG}}"
        },
        {
          "title": "Last known summary",
          "value": "{{LAST_KNOWN_SUMMARY}}"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "A follow-up prompt has been sent to {{SPOC_UPN}}.",
      "isSubtle": true,
      "size": "Small",
      "wrap": true,
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "---",
      "separator": true,
      "spacing": "Medium"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open in ADO",
      "url": "{{ADO_WORK_ITEM_URL}}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Override in ADO",
      "url": "{{ADO_WORK_ITEM_URL}}"
    }
  ]
}
